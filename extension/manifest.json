{
  "manifest_version": 3,
  "name": "DarkVolt Audio - Professional DJ Streaming",
  "version": "1.0.0",
  "description": "🚀 DarkVolt Native Audio Engine - Capture system audio for professional DJ streaming directly in your browser",
  
  "author": "DarkVolt Team",
  "homepage_url": "https://darkvolt.com",
  
  "permissions": [
    "desktopCapture",
    "activeTab",
    "scripting"
  ],
  
  "host_permissions": [
    "http://localhost:3000/*",
    "https://darkvolt.com/*",
    "https://*.darkvolt.com/*",
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://soundcloud.com/*",
    "https://www.soundcloud.com/*"
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*", "https://darkvolt.com/*", "https://*.darkvolt.com/*", "https://www.youtube.com/*", "https://youtube.com/*", "https://soundcloud.com/*", "https://www.soundcloud.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "🚀 DarkVolt Audio Engine"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["http://localhost:3000/*", "https://darkvolt.com/*", "https://*.darkvolt.com/*", "https://www.youtube.com/*", "https://youtube.com/*", "https://soundcloud.com/*", "https://www.soundcloud.com/*"]
    }
  ],
  
  "externally_connectable": {
    "matches": ["http://localhost:3000/*", "https://darkvolt.com/*", "https://*.darkvolt.com/*", "https://www.youtube.com/*", "https://youtube.com/*", "https://soundcloud.com/*", "https://www.soundcloud.com/*"]
  }
}
