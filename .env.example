# Analytics configuration
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Discord OAuth2 (connexion avec Discord)
# 1. Créer une application sur https://discord.com/developers/applications
# 2. Onglet OAuth2 > ajouter les Redirect URIs :
#      http://localhost:5173/auth/discord   (développement)
#      https://darkvolt.fr/auth/discord     (production)
# 3. Copier le Client ID ci-dessous (le Client Secret n'est PAS nécessaire — flux PKCE)
VITE_DISCORD_CLIENT_ID=1485621688912576532

# DarkVolt API & Socket.IO
# En dev : lancer "npm run dev:server" dans un second terminal (port 3001)
# En production : laisser vide (même origine)
VITE_API_URL=

# Serveur RTMP (OBS → ici)
# Ex: rtmp://ton-serveur.fr:1935/live
RTMP_URL=rtmp://localhost:1935/live

# Owncast (optionnel) — si tu as un serveur Owncast configuré
# Ex: http://ton-serveur.fr:8080
VITE_OWNCAST_URL=

# Discord Webhook pour Recrutement DJ
